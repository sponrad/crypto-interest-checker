{
  "expo": {
    "name": "Crypto Checker",
    "slug": "crypto-interest-checker",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "primaryColor": "#000000",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "buildNumber": "1.0.6",
      "supportsTablet": true,
      "bundleIdentifier": "com.sponrad.cryptointerestchecker",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Enabling Face ID allows you quick and secure access to your data."
      }
    },
    "android": {
      "versionCode": 10,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.sponrad.cryptointerestchecker",
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#000000",
      "themeColor": "#000000",
      "barStyle": "black-translucent",
      "display": "standalone",
      "orientation": "portrait",
      "splash": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      }
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-secure-store",
      "expo-font"
    ]
  }
}
